# Host `npm run dev` env template → copy to root `.env.local`. NOT used by the Docker deploy,
# which reads infra/supabase/.env instead.
#
# Public Supabase client config. Safe to expose when RLS is enabled.
# Local self-hosted stack: the browser hits Kong on http://localhost:8000.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
# = the local ANON_KEY from infra/supabase/.env
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Backend-only secrets. Never prefix with NEXT_PUBLIC_ and never import in client code.
SUPABASE_SERVICE_ROLE_KEY=never-use-this-in-browser-code

# Public base URL of the app (e.g. https://hr.example.com). Used to build
# password-reset/invite links from a configured origin instead of request
# headers (host-header-poisoning defence). OPTIONAL: falls back to request
# headers if unset — set it in production self-host deployments.
APP_URL=

# App-originated transactional email (Resend HTTP API) — used by the
# src/server/email.ts notification boundary. OPTIONAL: if RESEND_API_KEY is
# blank/unset, app notifications degrade to an audited "email.skipped" — they
# never crash boot or fail a Server Action. (Distinct from the GoTrue SMTP block
# in infra/supabase/.env, which handles auth emails.)
# Sandbox sender onboarding@resend.dev only delivers to the Resend account owner
# until a domain is verified.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=onboarding@resend.dev
EMAIL_FROM_NAME=KushHR
