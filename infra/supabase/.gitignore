# runtime data (must never be committed)
volumes/db/data
volumes/storage

# exported internal-CA cert material (generated by Caddy at first boot)
certs/

# local encrypted backups + the age key (data + secret — never commit)
backups/
backup/*.key
backup/age-key.txt

# secrets — ignore every .env variant, keep only the placeholder template
.env*
!.env.example
migrate/.env.cloud

test.http
docker-compose.override.yml
